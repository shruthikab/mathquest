{
  "version": 2,
  "routes": [
    {
      "src": "/(.+\\.js)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.css)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.png)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.jpg)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.svg)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.ico)",
      "dest": "/$1"
    },
    {
      "src": "/api/auth/google/callback",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/auth/google",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/import-questions",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
