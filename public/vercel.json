{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/styles.css",
      "headers": [{ "key": "Content-Type", "value": "text/css" }],
      "dest": "styles.css"
    },
    {
      "src": "/auth.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }],
      "dest": "auth.js"
    },
    {
      "src": "/app.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }],
      "dest": "app.js"
    },
    {
      "src": "/config-data.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }],
      "dest": "config-data.js"
    },
    {
      "src": "/solutions.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }],
      "dest": "solutions.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
